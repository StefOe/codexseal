Port 2222
ListenAddress 0.0.0.0

# Authentication — key-only, no passwords. Login is the non-root `coder` user.
PermitRootLogin no
PasswordAuthentication no
ChallengeResponseAuthentication no
UsePAM no
AuthorizedKeysFile .ssh/authorized_keys

# Security hardening
X11Forwarding no
AllowTcpForwarding yes
GatewayPorts no
PermitTunnel no

# Performance
UseDNS no
PrintLastLog no

# Keep-alive (required for VS Code Remote-SSH to stay connected)
ClientAliveInterval 30
ClientAliveCountMax 3

AcceptEnv LANG LC_*

# Give SSH / VS Code Remote-SSH sessions the same Codex home as a local run, so
# they read the login + settings from the bind-mounted ~/.codex directory.
SetEnv CODEX_HOME=/home/coder/.codex

# Log to stderr so `podman logs` captures it
SyslogFacility AUTH
LogLevel INFO
